---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((doc) => ({
    params: { id: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
---

<Base title={doc.data.title}>
  <div style="padding: 2rem 0;">
    <a href="/docs" style="font-size: 0.9rem; color: var(--text-muted);">&larr; All Docs</a>
    <h1 style="margin-top: 1rem; font-size: 2rem;">{doc.data.title}</h1>
    <div class="doc-content">
      <Content />
    </div>
  </div>
</Base>

<style>
  .doc-content {
    margin-top: 2rem;
    line-height: 1.7;
    font-size: 1rem;
    max-width: 750px;
  }
  .doc-content :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--text);
  }
  .doc-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .doc-content :global(p) {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .doc-content :global(ul), .doc-content :global(ol) {
    color: var(--text-muted);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .doc-content :global(li) { margin-bottom: 0.3rem; }
  .doc-content :global(strong) { color: var(--text); }
  .doc-content :global(a) { color: var(--accent); }
  .doc-content :global(code) {
    background: var(--bg-card);
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
  .doc-content :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1rem 0;
    font-size: 0.9rem;
  }
  .doc-content :global(pre code) {
    background: none;
    padding: 0;
  }
  .doc-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
  }
  .doc-content :global(th), .doc-content :global(td) {
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .doc-content :global(th) {
    background: var(--bg-card);
    font-weight: 600;
    color: var(--text);
  }
  .doc-content :global(td) {
    color: var(--text-muted);
  }
  .doc-content :global(blockquote) {
    border-left: 3px solid var(--accent-dim);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .doc-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
</style>
