---
import Base from "../layouts/Base.astro";

const categoryColors: Record<string, string> = {
  Framework: "#60a5fa",
  Language: "#a78bfa",
  Database: "#34d399",
  AI: "#f472b6",
  Testing: "#fbbf24",
  Standards: "#fb923c",
  Workflow: "#38bdf8",
  Communication: "#c084fc",
  Planning: "#facc15",
  Tooling: "#4ade80",
  Brand: "#f87171",
};

const skills = [
  { name: "Next.js App Router", category: "Framework", triggers: "app/**/*.tsx, app/**/*.ts", description: "Server Components, Server Actions, caching, async APIs, proxy.ts" },
  { name: "Astro Site", category: "Framework", triggers: "**/*.astro, astro.config.*", description: "Content collections, MDX, islands architecture" },
  { name: "Vite React Scaffold", category: "Framework", triggers: "vite.config.*", description: "Vite + React scaffolding patterns" },
  { name: "React Component Split", category: "Framework", triggers: "**/*.tsx refactor", description: "Component refactoring and splitting patterns" },
  { name: "TypeScript Expert", category: "Language", triggers: "**/*.ts, **/*.tsx", description: "Type safety patterns, generics, modern TS 5.x features" },
  { name: "Prisma + Neon", category: "Database", triggers: "prisma/**, *.prisma", description: "Schema design, Neon serverless adapter, migration patterns" },
  { name: "AI SDK Patterns", category: "AI", triggers: "imports: ai, @ai-sdk/*", description: "streamText, useChat, Agent class, tool definitions, AI Gateway" },
  { name: "Prompt Engineering", category: "AI", triggers: "prompt keywords", description: "System prompts, few-shot examples, evaluation, guardrails" },
  { name: "Responsible AI Governance", category: "AI", triggers: "prompt keywords", description: "Human-in-the-loop, accountability, developer-first AI" },
  { name: "Testing Automation", category: "Testing", triggers: "**/*.test.ts, **/*.spec.ts", description: "Jest, Vitest, Playwright, Cypress, mutation testing" },
  { name: "Given-When-Then", category: "Testing", triggers: "prompt keywords", description: "Acceptance criteria, BDD scenarios, user story breakdowns" },
  { name: "Engineering Practices", category: "Standards", triggers: "prompt keywords", description: "SOLID principles, clean code, testing strategies" },
  { name: "Accessibility First", category: "Standards", triggers: "prompt keywords", description: "WCAG standards, semantic HTML, ARIA, keyboard navigation" },
  { name: "Documentation Standards", category: "Standards", triggers: "**/*.md, docs/**", description: "Concise, clean, no repetition, no filler, no emojis" },
  { name: "Code Documentation", category: "Standards", triggers: "**/*.ts, **/*.tsx", description: "TSDoc with params, returns, throws. No inline comments." },
  { name: "Git Workflow", category: "Workflow", triggers: "bash: git, gh", description: "Commit conventions, branching, PR best practices" },
  { name: "CI/CD Pipelines", category: "Workflow", triggers: ".github/workflows/**", description: "GitHub Actions, secrets management, deployment strategies" },
  { name: "Epic Breakdown", category: "Workflow", triggers: "prompt keywords", description: "Break epics into prioritized, estimated user stories" },
  { name: "Retrospective", category: "Workflow", triggers: "prompt keywords", description: "What went well, what didn't, what to change" },
  { name: "Meeting Notes", category: "Communication", triggers: "prompt keywords", description: "Decisions, action items, owners, and deadlines" },
  { name: "Executive Summary", category: "Communication", triggers: "prompt keywords", description: "One-page summaries with key takeaways and recommendations" },
  { name: "Stakeholder Email", category: "Communication", triggers: "prompt keywords", description: "Status, blockers, asks, and next steps" },
  { name: "Slide Outline", category: "Communication", triggers: "prompt keywords", description: "One idea per slide, narrative arc, speaker notes" },
  { name: "Lab Planner", category: "Planning", triggers: "prompt keywords", description: "Hands-on workshops with time blocks and exercises" },
  { name: "Decision Log", category: "Planning", triggers: "prompt keywords", description: "Decisions with context, alternatives, and rationale" },
  { name: "Mermaid Diagrams", category: "Planning", triggers: "**/*.md, **/*.mdx", description: "Flowcharts, sequences, ERDs, state machines" },
  { name: "Docs Generator", category: "Planning", triggers: "docs/**, **/*.md", description: "READMEs, how-tos, runbooks, onboarding guides" },
  { name: "CLI Toolkit", category: "Tooling", triggers: "bin/**, commands/**", description: "Commander + Inquirer + Chalk patterns" },
  { name: "API Proxy Setup", category: "Tooling", triggers: "proxy/**, middleware/**", description: "Express proxy, server-side secret keeping" },
  { name: "Brand Voice", category: "Brand", triggers: "prompt keywords", description: "Writing voice and principles. Customize for your org." },
  { name: "Brand Style Guide", category: "Brand", triggers: "prompt keywords", description: "Visual design system. Colors, fonts, components." },
];

const categories = [...new Set(skills.map(s => s.category))];
---

<Base title="Skills" description="Auto-injected knowledge packets that activate based on what you're working on.">
  <div style="padding: 2rem 0 1rem;">
    <h1>Skills Catalog</h1>
    <p style="color: var(--text-muted); margin-top: 0.5rem; max-width: 600px;">
      Skills are knowledge that auto-injects when relevant. You don't call them.
      They activate based on file patterns, imports, and prompt keywords.
    </p>
    <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 0.75rem;">
      {skills.length} skills across {categories.length} categories.
      Build your own: <code style="background: var(--bg-card); padding: 0.15rem 0.4rem; border-radius: 0.25rem; font-size: 0.85em;">@skill-architect create a skill for [topic]</code>
    </p>
  </div>

  <table class="skill-table">
    <thead>
      <tr>
        <th>Skill</th>
        <th>Category</th>
        <th>Auto-Triggers</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {skills.map((skill) => (
        <tr>
          <td class="skill-name">{skill.name}</td>
          <td>
            <span
              class="category-badge"
              style={`color: ${categoryColors[skill.category] || "var(--text-muted)"}; border-color: ${categoryColors[skill.category] || "var(--border)"}`}
            >
              {skill.category}
            </span>
          </td>
          <td class="triggers">{skill.triggers}</td>
          <td class="desc">{skill.description}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <section class="how-skills-work">
    <h2>How Skills Work</h2>
    <p class="how-intro">Skills use progressive disclosure. Instead of loading everything into every conversation, Claude Code injects only what matches your current work.</p>

    <div class="how-grid">
      <div class="how-card">
        <h3>Two ways to activate</h3>
        <p>Run a skill directly with a slash command (<code>/setup</code>, <code>/epic-breakdown</code>). Or just work normally and Claude matches relevant skills automatically based on your files and questions.</p>
      </div>
      <div class="how-card">
        <h3>Context arrives just in time</h3>
        <p>Each skill defines when it should fire. When a match happens, the skill's content loads into Claude's context for that session. One injection per skill, so nothing repeats.</p>
      </div>
      <div class="how-card">
        <h3>Claude applies the knowledge</h3>
        <p>The skill shapes how Claude writes code, what patterns it follows, and what mistakes it avoids. Like having a specialist looking over your shoulder, but only when you're in their domain.</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .skill-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .skill-table th {
    text-align: left;
    padding: 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }
  .skill-table td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .skill-table tr:hover {
    background: var(--bg-card);
  }
  .skill-name {
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
  }
  .category-badge {
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid;
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    white-space: nowrap;
  }
  .triggers {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--accent);
  }
  .desc {
    color: var(--text-muted);
  }

  .how-skills-work {
    padding: 2.5rem 0;
    border-top: 1px solid var(--border);
    margin-top: 1.5rem;
  }
  .how-skills-work h2 {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
    font-family: 'Plus Jakarta Sans', 'Inter', system-ui, sans-serif;
  }
  .how-intro {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    max-width: 650px;
    line-height: 1.6;
  }
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .how-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
  .how-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .how-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .how-grid { grid-template-columns: 1fr; }
    .skill-table { font-size: 0.8rem; }
  }
</style>
