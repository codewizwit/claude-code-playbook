---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const starters = (await getCollection("starters")).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Standards" description="Role-based CLAUDE.md standards — pick your role and start working.">
  <div style="padding: 2rem 0 1rem;">
    <h1>Standards</h1>
    <p style="color: var(--text-muted); margin-top: 0.5rem; max-width: 600px;">
      A CLAUDE.md is your working agreement with Claude Code — your standards, preferences, and guardrails.
      Pick the one closest to your role, copy it, and customize.
    </p>
  </div>

  <div class="starter-grid">
    {starters.map((starter) => (
      <a href={`/standards/${starter.data.role}`} class="starter-card">
        <h3>{starter.data.role.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase())}</h3>
        <p>{starter.data.description}</p>
        <span class="file-name">CLAUDE.md</span>
      </a>
    ))}
  </div>

  <section class="how-to-use">
    <h2>How to Use</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">1</span>
        <div>
          <strong>Pick a role</strong>
          <p>Click a starter above to preview the full CLAUDE.md</p>
        </div>
      </div>
      <div class="step">
        <span class="step-num">2</span>
        <div>
          <strong>Copy the file</strong>
          <code>cp src/content/standards/developer/CLAUDE.md ~/.claude/CLAUDE.md</code>
        </div>
      </div>
      <div class="step">
        <span class="step-num">3</span>
        <div>
          <strong>Fill in the placeholders</strong>
          <p>Replace every <code>[PLACEHOLDER]</code> with your specifics</p>
        </div>
      </div>
      <div class="step">
        <span class="step-num">4</span>
        <div>
          <strong>Start working</strong>
          <p>Your preferences are active every session — no reminding needed</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .starter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .starter-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    color: var(--text);
    transition: border-color 0.15s;
  }
  .starter-card:hover {
    border-color: var(--accent-dim);
    text-decoration: none;
  }
  .starter-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .starter-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }
  .file-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--accent);
  }

  .how-to-use {
    padding: 2.5rem 0;
  }
  .how-to-use h2 {
    font-size: 1.35rem;
    margin-bottom: 1.25rem;
  }
  .steps {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--accent-dim);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    flex-shrink: 0;
  }
  .step p { color: var(--text-muted); font-size: 0.9rem; margin-top: 0.25rem; }
  .step code {
    display: inline-block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 0.3rem 0.6rem;
    border-radius: 0.25rem;
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }
</style>
